# Anthropic API key (required for agent)
ANTHROPIC_API_KEY=sk-ant-...

# Model config
MODEL_NAME=claude-sonnet-4-20250514

# Agent API cost controls (optional). Shorter runs + sliding context window save input tokens.
# PWN_AGENT_MAX_ITERATIONS=30
# PWN_AGENT_CONTEXT_TURNS=8
# PWN_AGENT_TOOL_RESULT_MAX=4500
# PWN_AGENT_RUN_EXPLOIT_SCRIPT_SNIP=1600
# PWN_AGENT_MAX_OUTPUT_TOKENS=3072
# Max chars for CLI --notes / --notes-file passed into the model (default 12000).
# PWN_AGENT_USER_CONTEXT_MAX=12000

# Optional: Ghidra headless decompilation (ghidra_decompile tool + bootstrap). Java must be reachable:
# `java` on PATH, or JAVA_HOME / PWN_JAVA_HOME pointing at a JDK (e.g. /usr/lib/jvm/default-java).
# GHIDRA_HOME=/opt/ghidra
# PWN_GHIDRA_HOME=/opt/ghidra
# JAVA_HOME=/usr/lib/jvm/default-java
# PWN_JAVA_HOME=/usr/lib/jvm/default-java
# PWN_AGENT_BOOTSTRAP_GHIDRA=1
# PWN_AGENT_BOOTSTRAP_GHIDRA_MAX_FUNCS=12
# PWN_AGENT_BOOTSTRAP_GHIDRA_TIMEOUT=300
# PWN_AGENT_BOOTSTRAP_GHIDRA_MAX_CHARS=6000
# PWN_AGENT_BOOTSTRAP_MAX_CHARS=2500
# PWN_AGENT_BOOTSTRAP_MAX_CHARS_WITH_GHIDRA=12000
