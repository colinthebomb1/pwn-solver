# Anthropic API key (required for agent)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI API key (optional, for RAG embeddings)
VOYAGE_API_KEY=pa-...

# Cohere API key (optional, for reranking)
COHERE_API_KEY=...

# Ghidra installation path
GHIDRA_HOME=/opt/ghidra

# Qdrant connection (optional, for RAG)
QDRANT_URL=http://localhost:6333

# Model config
MODEL_NAME=claude-sonnet-4-20250514

# Agent API cost controls (optional). Shorter runs + sliding context window save input tokens.
# MAX_AGENT_ITERATIONS is a legacy alias for PWN_AGENT_MAX_ITERATIONS.
# PWN_AGENT_MAX_ITERATIONS=15
# PWN_AGENT_CONTEXT_TURNS=8
# PWN_AGENT_TOOL_RESULT_MAX=4500
# PWN_AGENT_RUN_EXPLOIT_SCRIPT_SNIP=1600
# PWN_AGENT_MAX_OUTPUT_TOKENS=3072
